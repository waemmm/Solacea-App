<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Register screen root container -->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.solacea.controller.RegisterController"
           prefWidth="760"
           prefHeight="580"
           styleClass="auth-root"
           stylesheets="@/css/styles.css">

    <!-- Main split layout: branding panel + signup form -->
    <HBox alignment="CENTER" spacing="44" maxWidth="980" fillHeight="false">
        <!-- Left panel: logo, tagline, and feature preview cards -->
        <VBox alignment="CENTER_LEFT" spacing="12" maxWidth="390" minWidth="260" styleClass="auth-left-pane">
            <ImageView fitWidth="300" preserveRatio="true" smooth="true">
                <Image url="@/images/Solacea_nlogo.png"/>
            </ImageView>
            <Label text="Grow through what you feel.">
                <styleClass>
                    <String fx:value="auth-tagline"/>
                    <String fx:value="auth-tagline-large"/>
                </styleClass>
            </Label>
            <VBox spacing="12" styleClass="auth-showcase-panel">
                <HBox spacing="12" alignment="CENTER_LEFT" styleClass="auth-showcase-card">
                    <ImageView fitWidth="98" fitHeight="82" preserveRatio="true" smooth="true">
                        <Image url="@/images/1_4_Happy.jpg"/>
                    </ImageView>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="MOOD BLOOM PREVIEW" styleClass="auth-showcase-title"/>
                        <Label text="Watch your plant brighten as daily mood check-ins stay steady."
                               wrapText="true"
                               styleClass="auth-showcase-text"/>
                    </VBox>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT" styleClass="auth-showcase-card">
                    <ImageView fitWidth="98" fitHeight="82" preserveRatio="true" smooth="true">
                        <Image url="@/images/3_2_Sad_Droopy.jpg"/>
                    </ImageView>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="RECOVERY SPOTLIGHT" styleClass="auth-showcase-title"/>
                        <Label text="Gentle journaling and mood logs help your garden recover over time."
                               wrapText="true"
                               styleClass="auth-showcase-text"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>

        <!-- Right panel: signup card with fields and actions -->
        <VBox alignment="TOP_CENTER" prefWidth="440" maxWidth="440" styleClass="auth-card">
            <!-- Tab row: switch between Login and Sign Up -->
            <HBox alignment="CENTER" styleClass="tab-row">
                <Button text="LOG IN" onAction="#handleBackToLogin" prefWidth="220" styleClass="tab-button"/>
                <Button text="SIGN UP" prefWidth="220" styleClass="tab-button-active"/>
            </HBox>

            <!-- Registration form body -->
            <VBox alignment="TOP_CENTER" spacing="16" styleClass="auth-card-body">
                <VBox spacing="8" fillWidth="true">
                    <Label text="USERNAME" styleClass="field-label"/>
                    <TextField fx:id="usernameField" promptText="Choose a username" onAction="#handleRegister" styleClass="auth-input"/>
                </VBox>

                <VBox spacing="8" fillWidth="true">
                    <Label text="CREATE PASSWORD" styleClass="field-label"/>
                    <StackPane>
                        <PasswordField fx:id="passwordField" promptText="At least 8 characters" onAction="#handleRegister" styleClass="auth-input"/>
                        <TextField fx:id="passwordTextField" promptText="At least 8 characters" onAction="#handleRegister" visible="false" styleClass="auth-input"/>
                        <Button fx:id="eyeButton"
                                text="Show"
                                onAction="#togglePassword"
                                visible="false"
                                managed="false"
                                StackPane.alignment="CENTER_RIGHT"
                                styleClass="field-toggle-button"/>
                    </StackPane>
                </VBox>

                <VBox spacing="8" fillWidth="true">
                    <Label text="CONFIRM PASSWORD" styleClass="field-label"/>
                    <StackPane>
                        <PasswordField fx:id="confirmPasswordField" promptText="Repeat password" onAction="#handleRegister" styleClass="auth-input"/>
                        <TextField fx:id="confirmTextField" promptText="Repeat password" onAction="#handleRegister" visible="false" styleClass="auth-input"/>
                        <Button fx:id="confirmEyeButton"
                                text="Show"
                                onAction="#toggleConfirmPassword"
                                visible="false"
                                managed="false"
                                StackPane.alignment="CENTER_RIGHT"
                                styleClass="field-toggle-button"/>
                    </StackPane>
                </VBox>

                <Label fx:id="statusLabel" alignment="CENTER" wrapText="true" styleClass="status-label"/>

                <Region prefHeight="2"/>

                <!-- Submit button -->
                <Button text="SIGN UP" onAction="#handleRegister" prefWidth="350" defaultButton="true" styleClass="primary-button"/>
            </VBox>
        </VBox>
    </HBox>

    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>
</StackPane>
